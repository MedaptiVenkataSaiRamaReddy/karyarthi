# ═══════════════════════════════════════════════════════════════
# Karyarthi — .gitignore
# Covers: Java/Maven, Vite/Node, IntelliJ, VS Code, env files
# ═══════════════════════════════════════════════════════════════

# ── Java / Maven ──────────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*
.mvn/wrapper/maven-wrapper.jar

# ── Spring Boot ───────────────────────────────────────────────
HELP.md
spring-shell.log
*.log
logs/

# ── Uploads / Generated files (never commit user data) ────────
uploads/
uploads/**

# ── Environment & Secrets ─────────────────────────────────────
.env
.env.local
.env.production
.env.staging
.env.*.local
*.env
application-prod.yml
application-production.yml
secrets.yml

# ── Node / Vite / npm ─────────────────────────────────────────
frontend/node_modules/
node_modules/
frontend/dist/
dist/
frontend/.vite/
.vite/
frontend/.cache/
.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp
.pnp.js
package-lock.json   # keep yarn.lock OR package-lock.json, not both

# ── Vite build output (served from Spring static) ─────────────
src/main/resources/static/assets/
src/main/resources/static/index.html
# (These are generated by `npm run build` — don't commit them)

# ── IntelliJ IDEA ─────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
out/
.idea_modules/

# ── VS Code ───────────────────────────────────────────────────
.vscode/
*.code-workspace
.history/

# ── Eclipse ───────────────────────────────────────────────────
.classpath
.project
.settings/
.factorypath
bin/

# ── macOS ─────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── Windows ───────────────────────────────────────────────────
Thumbs.db
Thumbs.db:encryptedDatabase
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# ── Linux ─────────────────────────────────────────────────────
*~
.nfs*

# ── H2 local database files ───────────────────────────────────
*.db
*.mv.db
*.trace.db

# ── Miscellaneous ─────────────────────────────────────────────
*.swp
*.swo
*.tmp
*.bak
*.orig
*.rej
